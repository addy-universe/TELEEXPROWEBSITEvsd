generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model User {
  id               Int      @id @default(autoincrement())
  username         String   @unique
  password         String
  plainPassword    String   @default("")
  fullName         String
  employeeId       String?  @unique
  avatarUrl        String?
  role             String   // ADMIN, HEAD, HR, MANAGER, TL, AGENT
  phone            String?
  status           String   @default("ACTIVE") // ACTIVE, INACTIVE
  managerId        Int?
  tlId             Int?
  dailyWage        Float    @default(0)
  externalDialerId String?
  googleSheetSyncId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  manager          User?    @relation("ManagerRelation", fields: [managerId], references: [id])
  managedAgents    User[]   @relation("ManagerRelation")

  teamLeader       User?    @relation("TLRelation", fields: [tlId], references: [id])
  teamMembers      User[]   @relation("TLRelation")

  assignedLeads    Lead[]   @relation("AgentLeads")
  assignedTlLeads  Lead[]   @relation("TLLeads")
  uploadedLeads    Lead[]   @relation("UploadedLeads")

  remarks          Remark[]
  saleRecords      SaleRecord[]
  attendanceLogs   AttendanceLog[]
  attendanceSummaries AttendanceSummary[]
}

model Lead {
  id              Int      @id @default(autoincrement())
  customerName    String
  phone           String
  stateCity       String
  productVariant  String
  disposition     String?  // FOLLOW_UP, SALE_DONE, DELIVERED, NOT_RECEIVED, CANCELLED
  callbackAt      DateTime?
  assignedAgentId Int?
  assignedTlId    Int?
  uploadedByManagerId Int
  batchId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedAgent   User?    @relation("AgentLeads", fields: [assignedAgentId], references: [id])
  assignedTl      User?    @relation("TLLeads", fields: [assignedTlId], references: [id])
  uploadedBy      User     @relation("UploadedLeads", fields: [uploadedByManagerId], references: [id])

  remarks         Remark[]
  saleRecord      SaleRecord?
}

model Remark {
  id          Int      @id @default(autoincrement())
  leadId      Int
  agentId     Int
  disposition String
  note        String
  callbackAt  DateTime?
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id])
  agent       User     @relation(fields: [agentId], references: [id])
}

model SaleRecord {
  id              Int      @id @default(autoincrement())
  leadId          Int      @unique
  agentId         Int
  grossAmount     Float
  paymentType     String   // COD, PREPAID
  advanceAmount   Float    @default(0)
  deliveryCost    Float    @default(0)
  logisticsStatus String   @default("DISPATCHED") // DISPATCHED, DELIVERED, CANCELLED_RETURNED
  trackingId      String?
  courierName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lead            Lead     @relation(fields: [leadId], references: [id])
  agent           User     @relation(fields: [agentId], references: [id])
}

model AttendanceLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  status    String   // TIME_IN, TIME_OUT, BIO_BREAK, LUNCH_BREAK, TRAINING_BREAK, MEETING_BREAK
  timestamp DateTime @default(now())
  date      String   // YYYY-MM-DD format for easy querying

  user      User     @relation(fields: [userId], references: [id])
}

model AttendanceSummary {
  id                Int      @id @default(autoincrement())
  userId            Int
  date              String   // YYYY-MM-DD
  timeIn            DateTime?
  timeOut           DateTime?
  totalBreakMins    Int      @default(0)
  netProductiveHours Float   @default(0)
  dayStatus         String   @default("ABSENT") // PRESENT, HALF_DAY, ABSENT, AUTO_TIMEOUT
  hrOverride        Boolean  @default(false)
  hrOverrideStatus  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
